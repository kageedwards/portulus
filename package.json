{
  "name": "portulus",
  "version": "0.1.0",
  "description": "LXCF desktop client for Reticulum mesh networks",
  "type": "module",
  "main": "./src/main.js",
  "author": {
    "name": "Kage Edwards",
    "email": "kagemykel.edwards@gmail.com"
  },
  "scripts": {
    "start": "electron ./src/main.js",
    "test": "node --test tests/test_bridge_manager.js",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "ini": "^6.0.0",
    "lxcf": "github:kageedwards/lxcf"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "fast-check": "^4.6.0"
  },
  "build": {
    "appId": "com.portulus.app",
    "productName": "Portulus",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "!node_modules/lxcf/.venv/**",
      "!node_modules/lxcf/__pycache__/**"
    ],
    "extraResources": [
      {
        "from": "node_modules/lxcf",
        "to": "lxcf",
        "filter": ["**/*", "!.git/**", "!.venv/**", "!__pycache__/**", "!*.egg-info/**"]
      }
    ],
    "mac": {
      "icon": "assets/Portulus.icns",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "pkg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.social-networking"
    },
    "win": {
      "icon": "assets/Portulus.ico",
      "target": ["nsis"]
    },
    "linux": {
      "icon": "assets/Portulus.png",
      "target": ["AppImage", "deb"],
      "category": "Network"
    },
    "deb": {
      "depends": ["python3", "python3-venv", "python3-pip"]
    }
  }
}
